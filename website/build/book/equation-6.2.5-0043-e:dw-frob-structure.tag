<div class="equation" id="0043">
    <span class="equation-label"><a href="/tag/0043" data-tag="0043">6.2.5</a></span>
    <div>\begin{equation} \label{e:dw-frob-structure} \begin{aligned}  1 & = \frac{1}{|G|} [P_1]\\  \varepsilon ([P_ g]) & = \delta _{g,1}\\  [P_{g_1}][P_{g_2}]& =\sum _{h\in G} [P_{g_1 hg_2h^{-1}}]. \end{aligned} \end{equation}</div>
</div>