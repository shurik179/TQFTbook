    <div>\begin{equation} \label{e:spherical-E} E = \bigoplus _{i\in \mathcal{O}(\mathcal{C})} X_ i\boxtimes X_ i^*\in \mathcal{C}\boxtimes \mathcal{C}. \end{equation}</div>
