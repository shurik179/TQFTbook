<div class="equation" id="00ER">
    <span class="equation-label"><a href="/tag/00ER" data-tag="00ER">6.2.11</a></span>
    <div>\begin{equation} \label{e:dw-genusg} |G|^{2g-1} \sum _ i (\dim V_ i)^{2-2g} =\bigl | \{ a_1, \dots , a_ g, b_1, \dots , b_ g\in G\;  | \; \prod _ i [a_ i,b_ i]=1\}  \bigr |. \end{equation}</div>
</div>